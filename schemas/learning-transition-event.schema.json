{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/StegVerse-Labs/StegLearn/schemas/learning-transition-event.schema.json",
  "title": "StegLearn Learning Transition Event",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "event_id",
    "created_at",
    "entity_id",
    "entity_type",
    "event_type",
    "summary",
    "source_record_ids",
    "privacy"
  ],
  "properties": {
    "event_id": { "type": "string" },
    "created_at": { "type": "string", "format": "date-time" },
    "entity_id": { "type": "string" },
    "entity_type": {
      "type": "string",
      "enum": ["learner", "parent-steward", "ai-scaffold", "session", "artifact", "receipt", "portfolio", "curriculum-reference", "teaching-agent"]
    },
    "event_type": {
      "type": "string",
      "enum": ["wonder-captured", "activity-selected", "artifact-attached", "explanation-captured", "parent-reviewed", "receipt-accepted", "receipt-rejected", "portfolio-updated", "export-created", "ai-suggestion-created", "ai-suggestion-reviewed"]
    },
    "summary": { "type": "string" },
    "source_record_ids": {
      "type": "array",
      "items": { "type": "string" }
    },
    "evidence_notes": {
      "type": "array",
      "items": { "type": "string" }
    },
    "reviewed_by": { "type": "string" },
    "privacy": {
      "type": "string",
      "enum": ["private", "parent-approved-export", "public"]
    },
    "non_capture_note": { "type": "string" }
  }
}
